<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvReportHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Generar Alerta"
            android:textColor="@color/text_white"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutServerName"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:hint="Servidor Afectado"
            android:textColorHint="@color/text_gray"
            app:hintTextColor="@color/accent_green"
            app:boxStrokeColor="@color/accent_green"
            app:boxStrokeWidth="2dp"
            app:layout_constraintTop_toBottomOf="@+id/tvReportHeader">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etServerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:padding="16dp"
                android:textColor="@color/text_white"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutIssueTitle"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Asunto de la Falla"
            android:textColorHint="@color/text_gray"
            app:hintTextColor="@color/accent_green"
            app:boxStrokeColor="@color/accent_green"
            app:boxStrokeWidth="2dp"
            app:layout_constraintTop_toBottomOf="@+id/layoutServerName">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etIssueTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textColor="@color/text_white"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutIssueDescription"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Descripción detallada"
            android:textColorHint="@color/text_gray"
            app:hintTextColor="@color/accent_green"
            app:boxStrokeColor="@color/accent_green"
            app:boxStrokeWidth="2dp"
            app:layout_constraintTop_toBottomOf="@+id/layoutIssueTitle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etIssueDescription"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:gravity="top|start"
                android:padding="16dp"
                android:textColor="@color/text_white"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendWhatsApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:paddingVertical="14dp"
            android:text="Notificar por WhatsApp"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_green"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@+id/layoutIssueDescription"
            app:layout_constraintBottom_toBottomOf="parent"
            app:icon="@drawable/ic_send"
            app:iconGravity="textStart"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>